# Auth Service Configuration
PORT=3100
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-long-here
BETTER_AUTH_URL=http://localhost:3100

# Client Portal URL (for email verification redirect)
CLIENT_PORTAL_URL=http://localhost:5173

# Google OAuth (optional — enable for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (SMTP for verification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@clientfocus.co
